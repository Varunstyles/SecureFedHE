{
  "_comment": "SecureFedHE — DEV MODE CONFIG. Single PC testing only. Do NOT use for real deployment.",

  "ring": {
    "nodes": [
      { "id": 0, "name": "City General Hospital",        "ip": "", "port": 8000 },
      { "id": 1, "name": "Suburban Medical Clinic",      "ip": "", "port": 8001 },
      { "id": 2, "name": "Rural Health Centre",          "ip": "", "port": 8002 },
      { "id": 3, "name": "Community Wellness Center",    "ip": "", "port": 8003 }
    ],
    "rounds": 20,
    "timeout_s": 300,
    "skip_on_timeout": true
  },

  "privacy": {
    "dp_epsilon": 3.0,
    "dp_delta": 1e-5,
    "dp_sensitivity": 0.01,
    "clip_threshold": 0.5,
    "max_aggregation_weight": 100
  },

  "he": {
    "poly_modulus_degree": 8192,
    "target_layer": "fc2"
  },

  "zkp": {
    "gradient_dim": 32,
    "keys_dir": "keys",
    "setup_seed": "securefedhe_hospital_v1"
  },

  "tls": {
    "ca_cert":     "certs/ca.crt",
    "server_cert": "certs/node_SELF_ID/server.crt",
    "server_key":  "certs/node_SELF_ID/server.key",
    "client_cert": "certs/node_SELF_ID/client.crt",
    "client_key":  "certs/node_SELF_ID/client.key",
    "peer_certs": {
      "0": "certs/node_0/client.crt",
      "1": "certs/node_1/client.crt",
      "2": "certs/node_2/client.crt",
      "3": "certs/node_3/client.crt",
      "4": "certs/node_4/client.crt"
    }
  },

  "dashboard": {
    "port": 8080,
    "host": "127.0.0.1",
    "claude_api_key": ""
  },

  "model": {
    "type": "DiabetesNet",
    "input_dim": 8,
    "hidden_dim": 64,
    "output_dim": 2,
    "local_epochs": 5,
    "lr": 0.001,
    "batch_size": 16
  },

  "attack_simulation": {
  "enabled": true,
  "target_node": 2,
  "type": "backdoor",
  "poison_fraction": 0.3,
  "backdoor_target_class": 1
  },

  "audit": {
    "log_dir": "logs",
    "log_level": "INFO"
  }
}
